{
  "name": "express-todo",
  "version": "0.0.0",
  "private": true,
  "description": "Express backend exposing the same todo domain (actions + resources) to Claude via @tesseron/server, plus a REST HTTP API on the same state.",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tesseron/server": "workspace:*",
    "express": "^4.21.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}

{
  "name": "@tesseron/mcp",
  "version": "0.0.0",
  "description": "MCP gateway for Tesseron. Bridges WebSocket SDKs to MCP-compatible AI agents over stdio and Streamable HTTP.",
  "license": "BUSL-1.1",
  "author": "Kenny Vaneetvelde <kenny.vaneetvelde@gmail.com>",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "bin": {
    "tesseron-mcp": "./src/cli.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "start": "tsx src/cli.ts",
    "build": "tsup",
    "build:plugin": "tsup --config tsup-plugin.config.ts"
  },
  "dependencies": {
    "@tesseron/core": "workspace:*",
    "@tesseron/server": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@standard-schema/spec": "^1.0.0",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.13",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "vitest": "^2.1.0"
  }
}

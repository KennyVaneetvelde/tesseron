{
  "name": "@tesseron/vite",
  "version": "2.0.0",
  "description": "Vite plugin for Tesseron. Exposes /@tesseron/ws and bridges browser tabs to the gateway.",
  "license": "BUSL-1.1",
  "author": {
    "name": "Kenny Vaneetvelde",
    "email": "kenny.vaneetvelde@gmail.com",
    "url": "https://brainblendai.com/"
  },
  "homepage": "https://github.com/BrainBlend-AI/tesseron#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BrainBlend-AI/tesseron.git",
    "directory": "packages/vite"
  },
  "bugs": {
    "url": "https://github.com/BrainBlend-AI/tesseron/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude",
    "ai-agents",
    "vite",
    "plugin",
    "tesseron"
  ],
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "files": ["dist", "README.md", "LICENSE"],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.13",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vite": "^5.4.0"
  },
  "peerDependencies": {
    "vite": ">=4.0.0"
  },
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "require": "./dist/index.cjs"
      }
    }
  }
}

{
  "name": "@tesseron/react",
  "version": "2.6.0",
  "description": "React hooks adapter for Tesseron. useTesseronAction, useTesseronResource.",
  "license": "BUSL-1.1",
  "author": {
    "name": "Kenny Vaneetvelde",
    "email": "kenny.vaneetvelde@gmail.com",
    "url": "https://brainblendai.com/"
  },
  "homepage": "https://github.com/BrainBlend-AI/tesseron#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BrainBlend-AI/tesseron.git",
    "directory": "packages/react"
  },
  "bugs": {
    "url": "https://github.com/BrainBlend-AI/tesseron/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude",
    "ai-agents",
    "typescript",
    "sdk",
    "react",
    "hooks",
    "tesseron"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@tesseron/core": "workspace:*",
    "@tesseron/web": "workspace:*"
  },
  "devDependencies": {
    "@testing-library/react": "^16.1.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "jsdom": "^25.0.1",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "vitest": "^2.1.0"
  },
  "peerDependencies": {
    "@standard-schema/spec": "^1.0.0",
    "react": ">=18"
  },
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "require": "./dist/index.cjs"
      }
    }
  }
}

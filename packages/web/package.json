{
  "name": "@tesseron/web",
  "version": "1.0.0",
  "description": "Browser SDK for Tesseron. Declares actions and resources, opens a WebSocket to the local gateway.",
  "license": "BUSL-1.1",
  "author": "Kenny Vaneetvelde <kenny.vaneetvelde@gmail.com>",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@tesseron/core": "workspace:*"
  },
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "require": "./dist/index.cjs"
      }
    }
  }
}

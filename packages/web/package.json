{
  "name": "@tesseron/web",
  "version": "2.6.0",
  "description": "Browser SDK for Tesseron. Declares actions and resources, opens a WebSocket to the local gateway.",
  "license": "BUSL-1.1",
  "author": {
    "name": "Kenny Vaneetvelde",
    "email": "kenny.vaneetvelde@gmail.com",
    "url": "https://brainblendai.com/"
  },
  "homepage": "https://github.com/BrainBlend-AI/tesseron#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BrainBlend-AI/tesseron.git",
    "directory": "packages/web"
  },
  "bugs": {
    "url": "https://github.com/BrainBlend-AI/tesseron/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude",
    "ai-agents",
    "typescript",
    "sdk",
    "websocket",
    "browser",
    "tesseron"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@tesseron/core": "workspace:*"
  },
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "require": "./dist/index.cjs"
      }
    }
  }
}

{
  "mcpServers": {
    "tesseron": {
      "type": "stdio",
      "command": "node",
      "args": ["${CLAUDE_PLUGIN_ROOT}/server/index.cjs"],
      "env": {
        "TESSERON_PORT": "${TESSERON_PORT:-7475}",
        "TESSERON_HOST": "${TESSERON_HOST:-127.0.0.1}"
      }
    },
    "tesseron-docs": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@tesseron/docs-mcp"]
    }
  }
}
